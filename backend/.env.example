MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=dhammapada
DHAMMAPADA_DATA_FILE=data/dhammapada.json

# RAG embeddings
# Use local for immediate development, or openai for production-quality semantic retrieval.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Atlas Vector Search index name.
MONGODB_VECTOR_SEARCH_INDEX=verse_vector_index

# Optional LLM answer generation. Keep "none" for deterministic citation summaries.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
